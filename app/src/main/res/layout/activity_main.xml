<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.google.android.exoplayer2.ui.StyledPlayerView
        android:id="@+id/player_view_firme"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageView
        android:id="@+id/imagen_splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#1A1A1A"
        android:contentDescription="Splash"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/contenedor_menus"
        android:layout_width="550dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#E6000000"
        android:visibility="gone"
        android:padding="15dp"
        android:layout_gravity="start">

        <TextView
            android:id="@+id/text_nombre_lista_cabecera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BKO IPTV"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="5dp"
            android:gravity="center_horizontal" />

        <EditText
            android:id="@+id/input_buscador_canales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="🔍 Buscar canales..."
            android:textColor="#FFFFFF"
            android:textColorHint="#77FFFFFF"
            android:background="#22FFFFFF"
            android:padding="10dp"
            android:layout_marginVertical="10dp"
            android:textSize="14sp"
            android:inputType="text"
            android:autofillHints="name" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Columna Izquierda: Grupos -->
            <ListView
                android:id="@+id/list_view_grupos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:divider="#11FFFFFF"
                android:dividerHeight="0.5dp"
                android:nextFocusRight="@id/list_view_canales"
                android:focusable="true" />

            <!-- Separador sutil -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#22FFFFFF"
                android:layout_marginHorizontal="5dp" />

            <!-- Columna Derecha: Canales -->
            <ListView
                android:id="@+id/list_view_canales"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:divider="#11FFFFFF"
                android:dividerHeight="0.5dp"
                android:nextFocusLeft="@id/list_view_grupos"
                android:focusable="true" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/contenedor_configuracion"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#E6121212"
        android:visibility="gone"
        android:padding="20dp"
        android:layout_gravity="end">

        <TextView
            android:id="@+id/text_titulo_configuracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ AJUSTES"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="15dp"
            android:gravity="center_horizontal" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="10dp" />

        <ListView
            android:id="@+id/list_view_configuracion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#2A2A2A"
            android:dividerHeight="1dp"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>