<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.google.android.exoplayer2.ui.StyledPlayerView
        android:id="@+id/player_view_firme"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Pantalla de Fondo (Banner de Inicio) -->
    <RelativeLayout
        android:id="@+id/layout_fondo_inicio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="visible">

        <ImageView
            android:id="@+id/img_background_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/splash_banner"
            android:scaleType="centerCrop"
            android:alpha="1.0" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#88000000" />

        <TextView
            android:id="@+id/text_estado_reproduccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="BKO IPTV 3.5"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:visibility="gone" />

        <!-- Botones de Inicio -->
        <LinearLayout
            android:id="@+id/layout_botones_inicio"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:layout_marginStart="30dp"
            android:layout_marginTop="50dp"
            android:gravity="top"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_inicio_canales"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="5dp"
                android:background="@drawable/selector_botones_inicio"
                android:paddingHorizontal="25dp"
                android:text="⊞ CANALES"
                android:textColor="@color/selector_color_texto_inicio"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:focusable="true" />

            <Button
                android:id="@+id/btn_inicio_ajustes"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="5dp"
                android:background="@drawable/selector_botones_inicio"
                android:paddingHorizontal="25dp"
                android:text="⛭ AJUSTES"
                android:textColor="@color/selector_color_texto_inicio"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:focusable="true" />

            <Button
                android:id="@+id/btn_inicio_salir"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="5dp"
                android:background="@drawable/selector_botones_inicio"
                android:paddingHorizontal="25dp"
                android:text="✕ SALIR"
                android:textColor="@color/selector_color_texto_inicio"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:focusable="true" />

        </LinearLayout>

    </RelativeLayout>

    <!-- INFO EN ESQUINAS (Siempre arriba de todo) -->
    <LinearLayout
        android:id="@+id/layout_info_clima"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="25dp"
        android:layout_marginBottom="25dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_reloj_digital"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:alpha="0.9" />

        <TextView
            android:id="@+id/text_ciudad_clima"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="10sp"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:alpha="0.8" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_fecha_actual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="25dp"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="3"
        android:alpha="0.7" />

    <!-- Menú Lateral (Canales y Categorías) -->
    <LinearLayout
        android:id="@+id/contenedor_menus"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Cabecera con nombre de la lista y buscador -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="15dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_nombre_lista_cabecera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LISTA IPTV"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/input_buscador_canales"
                android:layout_width="300dp"
                android:layout_height="45dp"
                android:background="@android:drawable/edit_text"
                android:hint="Buscar canal..."
                android:textColor="#000000"
                android:padding="10dp"
                android:imeOptions="actionSearch"
                android:inputType="text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Columna Izquierda: Grupos -->
            <ListView
                android:id="@+id/list_view_grupos"
                android:layout_width="300dp"
                android:layout_height="match_parent"
                android:background="#22FFFFFF"
                android:divider="#44FFFFFF"
                android:dividerHeight="1dp" />

            <!-- Columna Derecha: Canales -->
            <ListView
                android:id="@+id/list_view_canales"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#22FFFFFF"
                android:dividerHeight="1dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Menú de Ajustes -->
    <LinearLayout
        android:id="@+id/contenedor_configuracion"
        android:layout_width="350dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#E6000000"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONFIGURACIÓN"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <ListView
            android:id="@+id/list_view_configuracion"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="5dp" />
    </LinearLayout>

    <!-- Overlay de Brillo -->
    <View
        android:id="@+id/overlay_brillo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0.0"
        android:visibility="visible"
        android:clickable="false"
        android:focusable="false" />

    <!-- Control de Brillo Pequeño -->
    <LinearLayout
        android:id="@+id/contenedor_ajuste_brillo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="50dp"
        android:background="#E6000000"
        android:orientation="vertical"
        android:padding="15dp"
        android:visibility="gone"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀ AJUSTE DE BRILLO"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_brillo_menos"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/selector_botones_inicio"
                android:focusable="true" />

            <TextView
                android:id="@+id/text_valor_brillo"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_brillo_mas"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/selector_botones_inicio"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" (Usar ← → para ajustar)"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:layout_marginTop="5dp" />

        <Button
            android:id="@+id/btn_cerrar_brillo"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/selector_botones_inicio"
            android:text="✕ CERRAR"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:paddingHorizontal="20dp"
            android:focusable="true" />

    </LinearLayout>

    <!-- Mini Reproductor (Multiview) -->
    <FrameLayout
        android:id="@+id/contenedor_mini_player"
        android:layout_width="220dp"
        android:layout_height="130dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="#000000"
        android:padding="2dp"
        android:visibility="gone">

        <com.google.android.exoplayer2.ui.StyledPlayerView
            android:id="@+id/player_view_mini"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <!-- Pantalla de Inicio (Splash) -->
    <RelativeLayout
        android:id="@+id/imagen_splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="visible">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/splash_banner"
            android:scaleType="centerCrop"
            android:contentDescription="Splash Banner" />

    </RelativeLayout>


</FrameLayout>